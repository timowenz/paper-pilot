# Copy this file to EITHER:
#   - `.env`   (same folder as docker-compose.ghcr.yml — recommended; Compose loads it automatically), OR
#   - `docker.env` and run: docker compose --env-file docker.env -f docker-compose.ghcr.yml up
#
# Rules: one KEY=value per line, no word `export`, no spaces around "=".
# GHCR_OWNER must be your GitHub username or org (lowercase), exactly as in the image URL.

GHCR_OWNER=your-github-username
OPENROUTER_API_KEY=sk-or-v1-...
# COHERENCE_MODEL=openai/gpt-oss-20b:free
# COHERENCE_MAX_TOKENS=16384
